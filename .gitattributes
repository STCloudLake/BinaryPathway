# ============================================
# Unity YAML — treat as text for meaningful diffs
# ============================================
*.unity text
*.prefab text
*.asset text
*.mat text
*.controller text
*.anim text
*.physicMaterial text
*.physicsMaterial2D text
*.playables text
*.mask text
*.brush text
*.flare text
*.fontsettings text
*.guiskin text
*.lighting text
*.preset text
*.renderTexture text
*.spriteatlas text
*.terrainlayer text
*.mixer text
*.signal text

# ============================================
# Git LFS — Binary Art Assets
# ============================================

# Textures / Images
*.png filter=lfs diff=lfs merge=lfs -text
